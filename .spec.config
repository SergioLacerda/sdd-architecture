# .spec.config — SPEC Architecture Configuration
# 
# This file tells agents and tooling where to find the SPEC framework.
# Copy this template to any project and edit the [spec] section.
#
# Usage:
#   python docs/ia/SCRIPTS/setup-wizard.py  (reads this file automatically)

[spec]
# Relative or absolute path to spec-architecture
# Examples:
#   ../spec-architecture          (sibling in /home/sergio/dev/)
#   /absolute/path/spec-architecture
#   ~/workspace/spec-architecture
spec_path = .

# Minimum required SPEC version
min_version = 2.1

# Discovery mode (local, remote, auto)
discovery_mode = local

[repository]
# Project name (for logs, metrics, reports)
name = spec-architecture

# Primary language (python, go, rust, typescript, etc)
language = python

# Project type (app, lib, service, framework, monorepo)
project_type = framework

[paths]
# Directory where SPEC compliance tests are located
spec_compliance_tests = tests/specs-ia-units

# Directory with SPEC scripts (used by agents)
spec_scripts_path = docs/ia/SCRIPTS

# Directory with SPEC rules (mandatory, do not change)
spec_canonical = docs/ia/CANONICAL

[metadata]
# Current framework version
version = 2.1

# Last update date
updated_at = 2026-04-19

# Project maintainer/owner
maintained_by = sergio@dev.local
