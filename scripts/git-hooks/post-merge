#!/bin/bash
# Post-merge Hook - SDD Architecture Framework
# Refresh local governance cache after merge

set -u
set -o pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT" || exit 1

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo -e "${YELLOW}[POST-MERGE] Updating governance cache...${NC}"

CACHE_FILE="$PROJECT_ROOT/packages/.sdd/agent_state.json"
if [ -f "$CACHE_FILE" ]; then
    rm -f "$CACHE_FILE"
    echo -e "${GREEN}✓ Cache cleared${NC}"
fi

if [ -x "$PROJECT_ROOT/.venv/bin/python" ]; then
    PYTHON_BIN="$PROJECT_ROOT/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
else
    PYTHON_BIN="python"
fi

if [ -f "$PROJECT_ROOT/tools/health/health_check.py" ]; then
    HEALTH_SCRIPT="$PROJECT_ROOT/tools/health/health_check.py"
elif [ -f "$PROJECT_ROOT/packages/tools/health_check.py" ]; then
    HEALTH_SCRIPT="$PROJECT_ROOT/packages/tools/health_check.py"
elif [ -f "$PROJECT_ROOT/packages/health_check.py" ]; then
    HEALTH_SCRIPT="$PROJECT_ROOT/packages/health_check.py"
else
    HEALTH_SCRIPT=""
fi

if [ -n "$HEALTH_SCRIPT" ]; then
    echo -e "${YELLOW}→ Warming up cache state...${NC}"
    "$PYTHON_BIN" "$HEALTH_SCRIPT" >/dev/null 2>&1 || true
    echo -e "${GREEN}✓ Cache warmed${NC}"
fi

echo -e "${GREEN}[POST-MERGE] Cache updated successfully.${NC}\n"
exit 0
