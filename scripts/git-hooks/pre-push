#!/bin/bash
# Pre-push Hook - SDD Architecture Framework (Not for Client Projects)
#
# Validates:
# - Health check
# - Governance compliance
#
# Skip only if absolutely necessary:
#   git push --no-verify

set -u
set -o pipefail

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT" || exit 1

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}[PRE-PUSH] Starting final validation before push...${NC}"

if [ -x "$PROJECT_ROOT/.venv/bin/python" ]; then
    PYTHON_BIN="$PROJECT_ROOT/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
else
    echo -e "${RED}✗ Python interpreter not found${NC}"
    exit 1
fi

HEALTH_SCRIPT=""
if [ -f "$PROJECT_ROOT/tools/health/health_check.py" ]; then
    HEALTH_SCRIPT="$PROJECT_ROOT/tools/health/health_check.py"
elif [ -f "$PROJECT_ROOT/packages/tools/health_check.py" ]; then
    HEALTH_SCRIPT="$PROJECT_ROOT/packages/tools/health_check.py"
elif [ -f "$PROJECT_ROOT/packages/health_check.py" ]; then
    HEALTH_SCRIPT="$PROJECT_ROOT/packages/health_check.py"
fi

if [ -z "$HEALTH_SCRIPT" ]; then
    echo -e "${RED}✗ Health check script not found${NC}"
    echo "  Expected one of:"
    echo "  - tools/health/health_check.py"
    echo "  - packages/tools/health_check.py"
    echo "  - packages/health_check.py"
    exit 1
fi

SDD_CMD=""
if [ -x "$PROJECT_ROOT/.venv/bin/sdd" ]; then
    SDD_CMD="$PROJECT_ROOT/.venv/bin/sdd"
elif command -v sdd >/dev/null 2>&1; then
    SDD_CMD="sdd"
fi

if [ -z "$SDD_CMD" ]; then
    echo -e "${RED}✗ sdd CLI command not found${NC}"
    echo "  Install and setup first (./setup.sh or sdd setup run)"
    exit 1
fi

echo -e "${YELLOW}→ Running full health check (fresh, no cache)...${NC}"
HEALTH_OUTPUT="$("$PYTHON_BIN" "$HEALTH_SCRIPT" 2>&1)"
HEALTH_STATUS=$?
if [ $HEALTH_STATUS -ne 0 ]; then
    echo -e "${RED}✗ Health check command failed${NC}"
    echo "$HEALTH_OUTPUT"
    exit 1
fi

if echo "$HEALTH_OUTPUT" | grep -q "FAILED"; then
    echo -e "${RED}✗ Health check failed${NC}"
    echo "$HEALTH_OUTPUT"
    exit 1
fi
echo -e "${GREEN}✓ Health check passed${NC}"

echo -e "${YELLOW}→ Running governance validation...${NC}"
GOV_OUTPUT="$("$SDD_CMD" governance validate 2>&1)"
GOV_STATUS=$?
if [ $GOV_STATUS -ne 0 ]; then
    echo -e "${RED}✗ Governance validation failed${NC}"
    echo "$GOV_OUTPUT"
    exit 1
fi
echo -e "${GREEN}✓ Governance validation passed${NC}"

BRANCH="$(git rev-parse --abbrev-ref HEAD)"
if git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
    COMMIT_COUNT="$(git rev-list --count @{u}..HEAD)"
else
    COMMIT_COUNT="(no upstream)"
fi

echo -e "${YELLOW}→ Summary for branch '$BRANCH':${NC}"
echo -e "  Commits to push: $COMMIT_COUNT"
echo -e "  Health: ${GREEN}✓ Healthy${NC}"
echo -e "  Governance: ${GREEN}✓ Validated${NC}"
echo -e "${GREEN}[PRE-PUSH] All checks passed. Push allowed.${NC}\n"

exit 0
